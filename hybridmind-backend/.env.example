# ============================================
# HybridMind Backend - Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to git!

# ============================================
# REQUIRED: OpenRouter API Key
# ============================================
# Get your key from: https://openrouter.ai/keys
# This ONE key provides access to ALL 200+ models:
# - Free: Llama, DeepSeek, Gemini, Mixtral
# - Premium: GPT-4, Claude, Grok, etc.
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# ============================================
# Server Configuration
# ============================================
PORT=3000
NODE_ENV=development
APP_URL=http://localhost:3000

# ============================================
# Model Configuration
# ============================================
DEFAULT_MODEL=llama-3.3-70b
MAX_RETRIES=3
REQUEST_TIMEOUT=120000

# ============================================
# Agent Configuration
# ============================================
AGENT_MAX_STEPS=10
AGENT_TIMEOUT=300000

# ============================================
# Logging
# ============================================
LOG_LEVEL=info
ENABLE_REQUEST_LOGGING=true

# ============================================
# Hybrid Architecture - Python AI Service
# ============================================
# Enable Python AutoGen service for advanced AI tasks
ENABLE_PYTHON_SERVICE=false
PYTHON_SERVICE_URL=http://localhost:8000
PYTHON_SERVICE_TIMEOUT=120000

# Force routing for testing
# FORCE_PYTHON_SERVICE=false
# FORCE_NODEJS_AGENTS=false
# DEBUG_HYBRID_ROUTING=false

# ============================================
# OLD API KEYS - NO LONGER NEEDED!
# ============================================
# The following keys are NO LONGER REQUIRED
# Everything routes through OpenRouter now:
# 
# OPENAI_API_KEY=           (removed)
# ANTHROPIC_API_KEY=        (removed)
# GROQ_API_KEY=             (removed)
# DEEPSEEK_API_KEY=         (removed)
# GEMINI_API_KEY=           (removed)
# QWEN_API_KEY=             (removed)
# MISTRAL_API_KEY=          (removed)
# XAI_API_KEY=              (removed)

# -- Dev test license keys (NODE_ENV=development only) --
TEST_KEY_FREE=hm-test-free
TEST_KEY_PRO=hm-test-pro
TEST_KEY_PRO_PLUS=hm-test-proplus
TEST_KEY_ENTERPRISE=hm-test-enterprise
