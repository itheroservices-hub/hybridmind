# HybridMind Python AI Service Configuration

# OpenRouter (Recommended - matches Node.js backend)
OPENROUTER_API_KEY=your-openrouter-key-here

# Or use OpenAI directly
OPENAI_API_KEY=your-openai-key-here

# Or use Ollama (Free, Local)
# No key needed - just install Ollama and run `ollama pull llama3.2`
OLLAMA_BASE_URL=http://localhost:11434/v1

# Node.js Backend URL (for MCP tools bridge)
NODEJS_BACKEND_URL=http://localhost:3000

# Service Configuration
SERVICE_PORT=8000
LOG_LEVEL=INFO
